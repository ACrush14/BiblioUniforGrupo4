<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Fundo decorativo -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.3"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/biblio_detalhes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/imageLogoAdm"
            android:layout_width="450dp"
            android:layout_height="210dp"
            android:layout_marginTop="45dp"
            android:contentDescription="Logo"
            android:src="@drawable/unifor_marca"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/textTituloAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Acesse sua Conta ADM"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/imageLogoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Bem vindo -->
        <TextView
            android:id="@+id/textBemVindoAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:text="Bem vindo de novo!"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/textTituloAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Erro -->
        <TextView
            android:id="@+id/textErroAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="Email ou senhas incorreto&#10;Preencha todos os campos"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/textBemVindoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Email -->
        <EditText
            android:id="@+id/editEmailAdm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input"
            android:hint="Digite seu e-mail"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="20dp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@id/textErroAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Senha -->
        <EditText
            android:id="@+id/editSenhaAdm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input"
            android:hint="Digite sua senha"
            android:inputType="textPassword"
            android:paddingHorizontal="20dp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@id/editEmailAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Credencial -->
        <EditText
            android:id="@+id/editCredencialAdm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input"
            android:hint="Digite sua credencial"
            android:inputType="text"
            android:paddingHorizontal="20dp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@id/editSenhaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Esqueceu senha -->
        <TextView
            android:id="@+id/textEsqueceuSenhaAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Esqueceu a Senha?"
            android:textColor="@color/biblio_detalhes"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/editCredencialAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEntrarAdm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="18dp"
            android:text="Entrar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="12dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/textEsqueceuSenhaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Criar conta -->
        <LinearLayout
            android:id="@+id/layoutCriarContaAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/buttonEntrarAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Não tem uma conta? "
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/textCriarContaAdm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Crie aqui"
                android:textColor="@color/biblio_detalhes"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- Espaço final -->
        <Space
            android:layout_width="0dp"
            android:layout_height="40dp"
            app:layout_constraintTop_toBottomOf="@id/layoutCriarContaAdm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>