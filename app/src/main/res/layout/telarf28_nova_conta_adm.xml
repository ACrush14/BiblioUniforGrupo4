<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Fundo decorativo -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.3"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/biblio_detalhes"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/textTituloCadastroAdm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:gravity="center"
            android:text="Seja bem vindo ao&#10;BiblioUnifor!"
            android:textColor="@color/black"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/textSubtituloCadastroAdm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="Vamos fazer sua conta de Administrador"
            android:textColor="#5F6368"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/textTituloCadastroAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nome completo -->
        <EditText
            android:id="@+id/editNomeCompletoAdm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="42dp"
            android:background="@drawable/bg_input"
            android:hint="Digite seu nome completo"
            android:paddingHorizontal="20dp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@id/textSubtituloCadastroAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Nome usuário -->
        <EditText
            android:id="@+id/editNomeUsuarioAdm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_input"
            android:hint="Digite seu nome de usuário"
            android:paddingHorizontal="20dp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@id/editNomeCompletoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Erro email -->
        <TextView
            android:id="@+id/textErroEmailAdmCadastro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="18dp"
            android:text="E-mail já cadastrado ou inválido"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/editNomeUsuarioAdm"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Email -->
        <EditText
            android:id="@+id/editEmailAdmCadastro"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:hint="Digite seu e-mail"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="20dp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@id/textErroEmailAdmCadastro"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Erro credencial -->
        <TextView
            android:id="@+id/textErroCredencialAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="18dp"
            android:text="Credencial já cadastrada ou inválida"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/editEmailAdmCadastro"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Credencial -->
        <EditText
            android:id="@+id/editCredencialAdmCadastro"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:hint="Digite sua credencial"
            android:paddingHorizontal="20dp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@id/textErroCredencialAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Senha -->
        <RelativeLayout
            android:id="@+id/layoutSenhaAdmCadastro"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/editCredencialAdmCadastro"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editSenhaAdmCadastro"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input"
                android:hint="Digite sua senha"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="48dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:importantForAutofill="no" />

            <ImageView
                android:id="@+id/iconOlhoSenhaAdmCadastro"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="@color/biblio_blue" />
        </RelativeLayout>

        <!-- Confirmar senha -->
        <RelativeLayout
            android:id="@+id/layoutConfirmarSenhaAdm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="18dp"
            app:layout_constraintTop_toBottomOf="@id/layoutSenhaAdmCadastro"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/editConfirmarSenhaAdm"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_input"
                android:hint="Confirme sua senha"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="48dp"
                android:textColor="@color/black"
                android:textColorHint="#9E9E9E"
                android:importantForAutofill="no" />

            <ImageView
                android:id="@+id/iconOlhoConfirmarSenhaAdm"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="4dp"
                android:clickable="true"
                android:contentDescription="@string/desc_mostrar_ocultar_senha"
                android:focusable="true"
                android:padding="10dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="@color/biblio_blue" />
        </RelativeLayout>

        <!-- Regras -->
        <TextView
            android:id="@+id/textRegrasSenhaAdm"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="18dp"
            android:text="• A senha deve conter pelo menos 8 caracteres&#10;• Um número&#10;• Uma letra maiúscula"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/layoutConfirmarSenhaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão criar -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCriarContaAdm"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="36dp"
            android:text="Criar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="12dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/textRegrasSenhaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Entre aqui -->
        <LinearLayout
            android:id="@+id/layoutEntreAquiAdm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/buttonCriarContaAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Já tem uma conta? "
                android:textColor="@color/black"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/textEntreAquiAdm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entre aqui"
                android:textColor="@color/biblio_blue"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Espaço final -->
        <Space
            android:layout_width="0dp"
            android:layout_height="40dp"
            app:layout_constraintTop_toBottomOf="@id/layoutEntreAquiAdm"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>