<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="170dp"
        android:background="#6EC1C3"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Engrenagem (Topo Esquerdo) -->
        <ImageView
            android:id="@+id/btnConfigAdm"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_manage"
            app:tint="#FFFFFF"
            android:contentDescription="Configurações ADM" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Verificar Mídia"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- PESQUISA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_rounded"
                android:paddingHorizontal="16dp"
                android:gravity="center_vertical"
                android:elevation="2dp">
                <EditText
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="Pesquisar solicitação..."
                    android:background="@android:color/transparent"
                    android:singleLine="true"/>
                <ImageView
                    android:id="@+id/btnFiltro"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="#6EC1C3"/>
            </LinearLayout>

            <!-- CARD EXEMPLO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <ImageView
                            android:layout_width="80dp"
                            android:layout_height="110dp"
                            android:src="@drawable/vidas_secas_capa"
                            android:scaleType="centerCrop"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="O Senhor dos Anéis"
                                android:textStyle="bold"
                                android:textSize="18sp"
                                android:textColor="#1B3434"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="J. R. R Tolkien"
                                android:textSize="14sp"
                                android:textColor="#415E5E"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ronaldo Alves"
                                android:textStyle="bold"
                                android:textSize="20sp"
                                android:layout_marginTop="12dp"
                                android:textColor="#6EC1C3"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solicitação: audiobook, pdf, braille"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"
                        android:textColor="#1B3434"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSolicitacoesUsuario"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="16dp"
                        android:text="Ver solicitações do usuário"
                        android:textAllCaps="false"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="10dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEnviarAudio"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Audiobook"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            app:backgroundTint="#6EC1C3"
                            app:cornerRadius="10dp"/>
                        <Space android:layout_width="8dp" android:layout_height="wrap_content"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnEnviarPdf"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="PDF"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            app:backgroundTint="#6EC1C3"
                            app:cornerRadius="10dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnBraille"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Notificar Braille Concluído"
                        android:textAllCaps="false"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="10dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnExcluirSolicitacao"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:text="Excluir Solicitação"
                        android:textAllCaps="false"
                        app:backgroundTint="#D65252"
                        app:cornerRadius="10dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- BARRA ADM PADRONIZADA -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/bottom_navigation_adm" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
