<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/biblio_cyan"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/btnNotificacao"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="@android:color/black" />

            <ImageView
                android:id="@+id/btnConfig"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@android:color/black" />
        </RelativeLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
            android:background="@android:color/white"
            android:padding="2dp" />

        <TextView
            android:id="@+id/textNomeUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="João Bobo"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bem vindo"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- PROCURAR LIVROS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BEM VINDO"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnProcurarLivros"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:text="Procurar Livros"
                        android:textSize="18sp"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/biblio_cyan"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- NOVOS BOTÕES DE PERFIL INTEGRADOS -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMinhaLivrariaDash"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Minha Livraria"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6CB6B3"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_agenda"
                app:iconGravity="end"
                app:iconTint="@android:color/black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnListaDesejoDash"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Lista de Desejo"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6CB6B3"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/btn_star"
                app:iconGravity="end"
                app:iconTint="@android:color/black" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAmigosDash"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Amigos"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6CB6B3"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistoricoDash"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Histórico"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6CB6B3"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStatusAluguelDash"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Status Aluguel"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6CB6B3"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvarDash"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="12dp"
                android:text="Salvar alterações"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="#6CB6B3"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSairDash"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="24dp"
                android:text="Sair da Conta"
                android:textAllCaps="false"
                android:textColor="#D32F2F"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="#6CB6B3"
                app:cornerRadius="12dp" />

            <!-- DESCOBRIR SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@android:color/black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Descobrir"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- LIVRO 1 -->
                    <include layout="@layout/item_livro_dashboard" />
                    <!-- LIVRO 2 -->
                    <include layout="@layout/item_livro_dashboard" />
                    <!-- LIVRO 3 -->
                    <include layout="@layout/item_livro_dashboard" />

                </LinearLayout>
            </HorizontalScrollView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#FFFFFF"
        android:elevation="12dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@android:drawable/ic_menu_view"
            android:contentDescription="@string/nav_home_desc" />

        <ImageView
            android:id="@+id/navCarrinho"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@android:drawable/ic_menu_add"
            android:contentDescription="@string/nav_carrinho_desc" />

        <ImageView
            android:id="@+id/navBusca"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@android:drawable/ic_menu_search"
            android:contentDescription="@string/nav_busca_desc" />

        <ImageView
            android:id="@+id/navFavoritos"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@android:drawable/ic_menu_agenda"
            android:contentDescription="@string/nav_favoritos_desc" />

        <ImageView
            android:id="@+id/navLista"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            android:contentDescription="@string/nav_lista_desc" />

        <ImageView
            android:id="@+id/navUsuario"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:contentDescription="@string/nav_perfil_desc" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
