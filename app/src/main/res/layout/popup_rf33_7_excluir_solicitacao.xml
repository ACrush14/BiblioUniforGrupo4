<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <!-- CONTEÚDO -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="30dp">

        <TextView
            android:id="@+id/txtLivroExcluir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="O Senhor dos Anéis - A sociedade do Anel"
            android:textColor="#6EC1C3"
            android:textSize="18sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/txtExcluirSolicitacao"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Tem certeza que\ndeseja excluir a\nsolicitação de\nRonaldo Alves?"
            android:textColor="#6EC1C3"
            android:textSize="30sp"
            android:textStyle="bold"
            android:gravity="center"/>

    </LinearLayout>

    <!-- BOTÕES -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCancelarExcluir"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="Cancelar"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#6EC1C3"/>

        <Button
            android:id="@+id/btnConfirmarExcluir"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="Excluir"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:backgroundTint="#D65252"/>

    </LinearLayout>

</LinearLayout>