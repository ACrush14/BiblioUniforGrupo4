<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- CONTEÚDO CENTRAL -->
    <LinearLayout
        android:id="@+id/layoutMensagemSolicitacao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="34dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonVoltarBiblioteca"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- ÍCONE DE SUCESSO -->
        <ImageView
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_marginBottom="32dp"
            android:src="@drawable/ic_check_circle"
            android:contentDescription="@string/desc_icone_sucesso"
            app:tint="@color/biblio_blue" />

        <!-- TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/titulo_confirmacao_biblioteca"
            android:textColor="@color/biblio_dark"
            android:textSize="26sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- TEXTO -->
        <TextView
            android:id="@+id/textSolicitacaoBiblioteca"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:lineSpacingExtra="5dp"
            android:text="@string/desc_confirmacao_biblioteca"
            android:textColor="@color/biblio_dark"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/textAguardeDias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/label_aguarde_dias"
            android:textColor="@color/biblio_blue"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- BOTÃO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonVoltarBiblioteca"
        android:layout_width="280dp"
        android:layout_height="56dp"
        android:layout_marginBottom="48dp"
        android:text="@string/btn_voltar_biblioteca"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="8dp"
        app:elevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>