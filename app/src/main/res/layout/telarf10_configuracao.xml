<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerConfig"
        android:layout_width="match_parent"
        android:layout_height="230dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Fundo decorativo -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.3"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Foto perfil -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imagePerfilUsuario"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="38dp"
            android:scaleType="centerCrop"
            android:src="@drawable/user_placeholder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

        <!-- Email + editar -->
        <LinearLayout
            android:id="@+id/layoutEmailUsuario"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imagePerfilUsuario">

            <TextView
                android:id="@+id/textUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Joãobobo@gmail.com"
                android:textColor="@color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnEditarUsuario"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="@color/black" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:id="@+id/scrollConfig"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerConfig"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- Nome -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nome"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/editNome"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/iconEditNome"
                    android:background="@android:color/transparent"
                    android:hint="Digite seu nome"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:text="João Bobo"
                    android:textColor="#444444"
                    android:textColorHint="#9E9E9E" />

                <ImageView
                    android:id="@+id/iconEditNome"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/black" />

            </RelativeLayout>

            <!-- Usuário -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuário"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/editUsuario"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/iconEditUsuario"
                    android:background="@android:color/transparent"
                    android:hint="Digite seu usuário"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:text="Joãobobo69420"
                    android:textColor="#444444"
                    android:textColorHint="#9E9E9E" />

                <ImageView
                    android:id="@+id/iconEditUsuario"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/black" />

            </RelativeLayout>

            <!-- Bio -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bio"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="130dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/editBio"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/iconEditBio"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="Digite sua bio"
                    android:inputType="textMultiLine"
                    android:padding="16dp"
                    android:text="Eu sou um cara que lê muitas coisas legais e adoro jogar Elden Ring. Sou mecânico de carro e moro em Parnamirim - RN."
                    android:textColor="#444444"
                    android:textColorHint="#9E9E9E" />

                <ImageView
                    android:id="@+id/iconEditBio"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_edit"
                    app:tint="@color/black" />

            </RelativeLayout>

            <!-- Senha atual -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Senha atual"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RelativeLayout
                android:id="@+id/layoutSenhaAtual"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="28dp">

                <EditText
                    android:id="@+id/editSenhaAtual"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_input"
                    android:hint="Digite sua senha"
                    android:importantForAutofill="no"
                    android:inputType="textPassword"
                    android:paddingStart="20dp"
                    android:paddingEnd="48dp"
                    android:text="************"
                    android:textColor="#444444"
                    android:textColorHint="#9E9E9E" />

                <ImageView
                    android:id="@+id/iconOlhoSenhaAtual"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="4dp"
                    android:clickable="true"
                    android:contentDescription="@string/desc_mostrar_ocultar_senha"
                    android:focusable="true"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_menu_view"
                    app:tint="@color/biblio_blue" />

            </RelativeLayout>

            <!-- Redefinir senha -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonRedefinirSenha"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="18dp"
                android:text="Redefinir Senha"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="12dp" />

            <!-- Apagar conta -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonApagarConta"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginBottom="40dp"
                android:text="Apagar Conta"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_red"
                app:cornerRadius="12dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>