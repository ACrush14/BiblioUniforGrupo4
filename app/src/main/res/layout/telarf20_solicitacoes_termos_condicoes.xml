<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/biblio_bg"
    android:paddingHorizontal="28dp"
    android:paddingTop="36dp"
    android:paddingBottom="28dp">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/textTituloTermos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/titulo_termos"
        android:textColor="@color/biblio_blue"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ÁREA CHECK -->
    <LinearLayout
        android:id="@+id/layoutTermos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/textTituloTermos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- CHECKBOX -->
        <CheckBox
            android:id="@+id/checkAceitarTermos"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:buttonTint="@color/biblio_blue"
            android:scaleX="1.2"
            android:scaleY="1.2" />

        <!-- TEXTO -->
        <TextView
            android:id="@+id/textAceiteTermos"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="@string/label_aceitar_termos"
            android:textColor="@color/biblio_blue"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- BOTÃO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonContinuarTermos"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:text="@string/btn_continuar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="8dp"
        app:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTermos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>