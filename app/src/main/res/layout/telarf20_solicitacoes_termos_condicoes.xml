<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- CONTEÚDO CENTRAL -->
    <LinearLayout
        android:id="@+id/layoutTelaTermos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="34dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/buttonConfirmarTermosTela"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloTelaTermos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Termos e condições"
            android:textColor="@color/biblio_blue"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- ÁREA CHECK -->
        <LinearLayout
            android:id="@+id/layoutCheckTelaTermos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="38dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- CHECK -->
            <CheckBox
                android:id="@+id/checkTelaAceitarTermos"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:buttonTint="@color/biblio_blue"
                android:scaleX="1.2"
                android:scaleY="1.2" />

            <!-- TEXTO -->
            <TextView
                android:id="@+id/textTelaAceitarTermos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="Eu aceito os termos e condições"
                android:textColor="@color/biblio_blue"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- BOTÃO -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonConfirmarTermosTela"
        android:layout_width="375dp"
        android:layout_height="54dp"
        android:layout_marginHorizontal="18dp"
        android:layout_marginBottom="120dp"
        android:text="Confirmar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="4dp"
        app:elevation="3dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>