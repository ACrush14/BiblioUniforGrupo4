<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER CYAN PADRONIZADO -->
    <LinearLayout
        android:id="@+id/headerPadrao"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="#6EC1C3"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnNotificacao"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_popup_reminder"
            android:contentDescription="Notificações"
            app:tint="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="Histórico"
            android:textColor="@android:color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnConfig"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_manage"
            android:contentDescription="Configurações"
            app:tint="@android:color/black" />
    </LinearLayout>

    <!-- HEADER PERFIL -->
    <LinearLayout
        android:id="@+id/headerPerfil"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:orientation="vertical"
        android:background="#6EC1C3"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/headerPadrao">

        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="Usuário" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="João Bobo"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="8dp" />

    </LinearLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerPerfil"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- BUSCA -->
            <EditText
                android:id="@+id/editBusca"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Pesquisar no histórico"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginBottom="16dp" />

            <!-- CARD 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_input_rounded"
                android:padding="12dp"
                android:elevation="3dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="60dp"
                        android:layout_height="90dp"
                        android:src="@drawable/o_alienista_capa"
                        android:contentDescription="Capa do livro" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:text="Vidas Secas"
                            android:textStyle="bold"
                            android:textColor="#415E5E"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:text="por Graciliano Ramos"
                            android:textSize="12sp"
                            android:textColor="#777777"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRemoverHIstorico"
                            android:layout_width="wrap_content"
                            android:layout_height="48dp"
                            android:layout_marginTop="6dp"
                            android:text="Remover do Histórico"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            app:backgroundTint="#D9534F"
                            app:cornerRadius="20dp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- DATA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:padding="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:text="Solicitado aluguel de Vidas Secas (14 de mar.)"
                    android:textSize="13sp"
                    android:textColor="#415E5E"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAV CONTAINER -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/bottom_navigation_placeholder" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
