<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerVerificarMidia"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="41dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloVerificarMidia"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verificar Mídia"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/headerVerificarMidia"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdicionarMidia"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Adicionar Mídia"
                android:textAllCaps="false"
                android:textSize="18sp"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="12dp"
                android:layout_marginBottom="20dp"/>

            <EditText
                android:id="@+id/etProcurarMidia"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/bg_input_rounded"
                android:hint="Procurar mídia..."
                android:paddingHorizontal="16dp"
                android:drawableEnd="@android:drawable/ic_menu_sort_by_size"
                android:layout_marginBottom="24dp"/>

            <!-- CARD DO LIVRO -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="3dp"
                android:layout_marginBottom="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">
                    <ImageView
                        android:layout_width="90dp"
                        android:layout_height="130dp"
                        android:src="@drawable/o_alienista_capa"
                        android:scaleType="centerCrop"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="16dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="O Senhor dos Aneis" android:textColor="#000000" android:textStyle="bold" android:textSize="16sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J. R. R. Tolkien" android:textColor="#333333" android:layout_marginTop="4dp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ISBN: 8595084750" android:textColor="#333333" android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditarInformacoes"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="Editar informações"
                android:textAllCaps="false"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="8dp"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>

    <!-- BARRA ADM PADRONIZADA -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/bottom_navigation_adm" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
