<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/biblio_bg"
    android:padding="18dp">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/textTituloSolicitacoesPopup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Solicitações"
        android:textColor="@color/black"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSolicitacaoLivro"
        android:layout_width="0dp"
        android:layout_height="140dp"
        android:layout_marginTop="16dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/textTituloSolicitacoesPopup"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="12dp">

            <!-- CAPA -->
            <ImageView
                android:id="@+id/imageLivroSolicitado"
                android:layout_width="76dp"
                android:layout_height="112dp"
                android:scaleType="centerCrop"
                android:src="@drawable/o_alienista_capa" />

            <!-- TÍTULO -->
            <TextView
                android:id="@+id/textTituloLivroSolicitado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/imageLivroSolicitado"
                android:layout_marginStart="14dp"
                android:text="O Ceifador"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- AUTOR -->
            <TextView
                android:id="@+id/textAutorLivroSolicitado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textTituloLivroSolicitado"
                android:layout_toEndOf="@id/imageLivroSolicitado"
                android:layout_marginStart="14dp"
                android:text="por Neal Shusterman"
                android:textColor="#555555"
                android:textSize="14sp" />

            <!-- DATA -->
            <TextView
                android:id="@+id/textDataLivroSolicitado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/textAutorLivroSolicitado"
                android:layout_toEndOf="@id/imageLivroSolicitado"
                android:layout_marginStart="14dp"
                android:text="23 mar. 2018"
                android:textColor="#777777"
                android:textSize="13sp" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>