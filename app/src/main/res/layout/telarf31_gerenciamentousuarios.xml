<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    tools:context=".TelaGestaoUsuariosADM">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerGestaoUsuarios"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULOS -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="41dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloGestaoUsuarios"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gestão de usuários"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ÁREA DE BUSCA -->
    <LinearLayout
        android:id="@+id/layoutBuscaUsuarios"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/biblio_bg"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="14dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerGestaoUsuarios">

        <!-- TEXTO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Procurar"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <!-- INPUT -->
        <EditText
            android:id="@+id/editBuscarUsuario"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:background="@drawable/bg_input_rounded"
            android:hint="Procure um usuário"
            android:paddingHorizontal="18dp"
            android:textColor="@color/black"
            android:textColorHint="#888888"
            android:textSize="15sp"
            android:singleLine="true" />

    </LinearLayout>

    <!-- LINHA -->
    <View
        android:id="@+id/linhaBuscaUsuarios"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#7A7A7A"
        app:layout_constraintTop_toBottomOf="@id/layoutBuscaUsuarios" />

    <!-- LISTA -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/linhaBuscaUsuarios"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white">

            <!-- ITEM 1 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingHorizontal="18dp">

                <!-- FOTO -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUsuario1"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="29dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <!-- NOME -->
                <TextView
                    android:id="@+id/textUsuario1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="22dp"
                    android:layout_toEndOf="@id/cardUsuario1"
                    android:text="Ronaldo Alves"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#7A7A7A" />

            <!-- ITEM 2 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUsuario2"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="29dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/textUsuario2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="22dp"
                    android:layout_toEndOf="@id/cardUsuario2"
                    android:text="Robson Gonçalves"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#7A7A7A" />

            <!-- ITEM 3 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUsuario3"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="29dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/textUsuario3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="22dp"
                    android:layout_toEndOf="@id/cardUsuario3"
                    android:text="Vitoria Ferreira"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#7A7A7A" />

            <!-- ITEM 4 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUsuario4"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="29dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/textUsuario4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="22dp"
                    android:layout_toEndOf="@id/cardUsuario4"
                    android:text="Marta Viana"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#7A7A7A" />

            <!-- ITEM 5 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="92dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardUsuario5"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="29dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/textUsuario5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="22dp"
                    android:layout_toEndOf="@id/cardUsuario5"
                    android:text="Adriano de Souza"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#7A7A7A" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>