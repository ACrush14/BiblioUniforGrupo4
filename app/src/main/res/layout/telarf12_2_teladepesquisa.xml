<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerPesquisaResultado"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- FUNDO DECORATIVO -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.3"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imagePerfilPesquisaResultado"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="28dp"
            android:scaleType="centerCrop"
            android:src="@drawable/user_placeholder"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

        <!-- TEXTO -->
        <TextView
            android:id="@+id/textTituloPesquisaResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Vamos procurar"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imagePerfilPesquisaResultado" />

        <TextView
            android:id="@+id/textBemVindoPesquisaResultado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Bem vindo"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textTituloPesquisaResultado" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerPesquisaResultado"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <!-- BOTÕES -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonBuscarTituloResultado"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Procurar por Título"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/biblio_detalhes"
                    app:cornerRadius="2dp"
                    app:strokeColor="@color/black"
                    app:strokeWidth="1dp" />

                <Space
                    android:layout_width="6dp"
                    android:layout_height="wrap_content" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonBuscarISBNResultado"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="Procurar por ISBN"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/biblio_detalhes"
                    app:cornerRadius="2dp"
                    app:strokeColor="@color/black"
                    app:strokeWidth="1dp" />

            </LinearLayout>

            <!-- INPUT -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_input">

                <EditText
                    android:id="@+id/editPesquisarLivroResultado"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@+id/iconFiltroResultado"
                    android:background="@android:color/transparent"
                    android:hint="O alienista"
                    android:paddingStart="16dp"
                    android:paddingEnd="8dp"
                    android:textColor="#444444"
                    android:textColorHint="#999999" />

                <ImageView
                    android:id="@+id/iconFiltroResultado"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="@color/black" />

            </RelativeLayout>

            <!-- BOTÃO -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonProcurarResultado"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="22dp"
                android:text="Procurar"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@color/biblio_blue"
                app:cornerRadius="10dp"
                app:elevation="4dp" />

            <!-- CARD LIVRO 1 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <!-- CAPA -->
                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/o_alienista_capa" />

                    <!-- INFOS -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <!-- TOPO -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="O Alienista"
                                android:textColor="@color/black"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● ● ●"
                                android:textColor="@color/black"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <!-- AUTOR -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="por Machado de Assis"
                            android:textColor="#444444"
                            android:textSize="14sp" />

                        <!-- DATA -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="18 dez. 2019"
                            android:textColor="#666666"
                            android:textSize="13sp" />

                        <!-- BOTÃO -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonAdicionarLista1"
                            android:layout_width="160dp"
                            android:layout_height="52dp"
                            android:layout_marginTop="18dp"
                            android:text="Adicionar a Lista"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            app:backgroundTint="@color/biblio_detalhes"
                            app:cornerRadius="2dp"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- CARD LIVRO 2 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="120dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="110dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/o_alienista_capa" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="O Alienista"
                                android:textColor="@color/black"
                                android:textSize="20sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="● ● ●"
                                android:textColor="@color/black"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="por Machado de Assis"
                            android:textColor="#444444"
                            android:textSize="14sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="16 set. 2021"
                            android:textColor="#666666"
                            android:textSize="13sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonAdicionarLista2"
                            android:layout_width="160dp"
                            android:layout_height="52dp"
                            android:layout_marginTop="18dp"
                            android:text="Adicionar a Lista"
                            android:textAllCaps="false"
                            android:textColor="@color/white"
                            android:textStyle="bold"
                            app:backgroundTint="@color/biblio_detalhes"
                            app:cornerRadius="2dp"
                            app:strokeColor="@color/black"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>