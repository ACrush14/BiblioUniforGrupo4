<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#6EC1C3">

    <!-- TIPO SOLICITAÇÃO -->

    <Spinner
        android:id="@+id/spinnerTipoSolicitacao"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="#FFFFFF"
        android:padding="10dp"/>

    <!-- NOME USUÁRIO -->

    <EditText
        android:id="@+id/edtNomeUsuario"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="16dp"
        android:hint="Nome do usuário..."
        android:background="#FFFFFF"
        android:padding="15dp"/>

    <!-- BOTÃO SALVAR -->

    <Button
        android:id="@+id/btnSalvarFiltro"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="20dp"
        android:text="Salvar Filtro"
        android:textStyle="bold"
        android:textColor="#1B3434"
        android:backgroundTint="#FFFFFF"/>

    <!-- BOTÃO LIMPAR -->

    <Button
        android:id="@+id/btnLimparFiltro"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="12dp"
        android:text="Limpar Filtragem"
        android:textStyle="bold"
        android:textColor="#1B3434"
        android:backgroundTint="#FFFFFF"/>

    <!-- OPÇÕES -->

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="20dp"
        android:background="#3E9EA1"
        android:padding="15dp">

        <Button
            android:id="@+id/btnPdf"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="PDF"
            android:textColor="#1B3434"
            android:backgroundTint="#87DEDE"/>

        <Button
            android:id="@+id/btnAudioBook"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="10dp"
            android:text="Audiobook"
            android:textColor="#1B3434"
            android:backgroundTint="#87DEDE"/>

        <Button
            android:id="@+id/btnBraille"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="10dp"
            android:text="Braille"
            android:textColor="#1B3434"
            android:backgroundTint="#87DEDE"/>

        <Button
            android:id="@+id/btnAluguel"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="10dp"
            android:text="Aluguel"
            android:textColor="#1B3434"
            android:backgroundTint="#87DEDE"/>

    </LinearLayout>

</LinearLayout>