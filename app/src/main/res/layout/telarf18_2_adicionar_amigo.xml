<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerAdicionarAmigo"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/biblio_detalhes"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-260dp"
            android:layout_marginTop="-120dp"
            android:alpha="0.18"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white" />

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloAdicionarAmigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-40dp"
            android:text="Adicionar Amigo"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- CONTEÚDO -->
    <LinearLayout
        android:id="@+id/layoutConteudoAdicionar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/headerAdicionarAmigo">

        <!-- INPUT -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardInputAdicionar"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white">

            <EditText
                android:id="@+id/editPesquisarAmigoNovo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:hint="Escreva aqui o nome do usuário..."
                android:paddingHorizontal="20dp"
                android:textColor="@color/black"
                android:textColorHint="#777777"
                android:textSize="15sp"
                android:inputType="textPersonName" />

        </androidx.cardview.widget.CardView>

        <!-- BOTÃO -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonProcurarAmigoNovo"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="28dp"
            android:text="Procurar"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_detalhes"
            app:cornerRadius="12dp"
            app:elevation="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>