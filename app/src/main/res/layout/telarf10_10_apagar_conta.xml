<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_popup">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/apagar_conta_titulo"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#6EC1C3"
        android:layout_gravity="center"/>

    <!-- Subtitle -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/apagar_conta_subtitulo"
        android:textSize="16sp"
        android:textColor="#6EC1C3"
        android:layout_gravity="center"
        android:layout_marginTop="4dp"/>

    <!-- Error Message -->
    <TextView
        android:id="@+id/textErroPopup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/apagar_conta_erro"
        android:textColor="#E53935"
        android:visibility="gone"
        android:layout_marginTop="8dp"
        android:layout_gravity="center"/>

    <!-- Password Input -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginTop="12dp">

        <EditText
            android:id="@+id/editSenhaPopup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_input_pill"
            android:paddingStart="16dp"
            android:paddingEnd="48dp"
            android:hint="@string/hint_sua_senha"
            android:inputType="textPassword"
            android:importantForAutofill="no"/>

        <ImageView
            android:id="@+id/iconOlho"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="4dp"
            android:clickable="true"
            android:contentDescription="@string/desc_mostrar_ocultar_senha"
            android:focusable="true"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_view" />
    </RelativeLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnVoltarPopup"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="55dp"
            android:text="@string/voltar"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_input_pill"
            android:backgroundTint="#6EC1C3"
            android:textAllCaps="false"/>

        <Space android:layout_width="12dp" android:layout_height="1dp"/>

        <Button
            android:id="@+id/btnConfirmarPopup"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="55dp"
            android:text="@string/btn_confirmar"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_input_pill"
            android:backgroundTint="#6EC1C3"
            android:textAllCaps="false"/>
    </LinearLayout>

</LinearLayout>