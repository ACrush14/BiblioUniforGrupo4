<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- TOPO AZUL CIANO -->
    <LinearLayout
        android:id="@+id/headerAmigos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#6EC1C3"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Sininho -->
            <ImageView
                android:id="@+id/btnNotificacao"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:src="@android:drawable/ic_popup_reminder"
                android:contentDescription="Notificações"
                app:tint="@android:color/black" />

            <!-- Engrenagem -->
            <ImageView
                android:id="@+id/btnConfig"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_menu_manage"
                android:contentDescription="Configurações"
                app:tint="@android:color/black" />

            <!-- Foto do Usuário Centralizada -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgPerfilUsuario"
                android:layout_width="85dp"
                android:layout_height="85dp"
                android:layout_centerHorizontal="true"
                android:background="@android:color/white"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

        </RelativeLayout>

        <!-- Título Amigos -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Amigos"
            android:textColor="@android:color/black"
            android:textSize="22sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- ÁREA DE PESQUISA -->
    <LinearLayout
        android:id="@+id/llPesquisa"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerAmigos">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Procurar"
            android:textColor="#1B3434"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etSearchAmigo"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:background="@drawable/bg_input_pill"
                android:hint="Procure um amigo"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:inputType="text" />

            <!-- Botão + FORA da caixa de texto -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdicionarAmigo"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="12dp"
                android:text="+"
                android:textSize="24sp"
                android:padding="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="#6EC1C3"
                app:cornerRadius="25dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- LISTA DE AMIGOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAmigos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/llPesquisa"
        app:layout_constraintBottom_toTopOf="@id/includeBottomNav"
        tools:listitem="@layout/item_amigo" />

    <!-- BARRA DE TAREFAS -->
    <include
        android:id="@+id/includeBottomNav"
        layout="@layout/bottom_navigation_placeholder"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>