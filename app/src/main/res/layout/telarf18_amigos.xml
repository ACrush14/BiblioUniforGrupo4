<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAmigos"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO -->
        <View
            android:layout_width="240dp"
            android:layout_height="240dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.15"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoUsuario"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_marginTop="44dp"
            app:cardCornerRadius="46dp"
            app:cardElevation="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/imageUsuario"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloAmigos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Amigos"
            android:textColor="@color/white"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoUsuario"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- ÁREA ADICIONAR AMIGOS -->
    <LinearLayout
        android:id="@+id/layoutAdicionarAmigos"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@color/biblio_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/headerAmigos">

        <!-- ÍCONE + -->
        <ImageView
            android:id="@+id/btnAdicionarAmigo"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/black" />

        <!-- TEXTO -->
        <TextView
            android:id="@+id/textAdicionarAmigos"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:text="adicionar amigos"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- LINHA -->
    <View
        android:id="@+id/linhaAdicionarAmigos"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#777777"
        app:layout_constraintTop_toBottomOf="@id/layoutAdicionarAmigos" />

    <!-- SCROLL -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/linhaAdicionarAmigos"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white">

            <!-- ITEM 1 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/fotoAmigo1"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/nomeAmigo1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:layout_toEndOf="@id/fotoAmigo1"
                    android:text="Ronaldo Alves"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/menuAmigo1"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/white"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:text="•••"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#777777" />

            <!-- ITEM 2 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/fotoAmigo2"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/nomeAmigo2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:layout_toEndOf="@id/fotoAmigo2"
                    android:text="Robson Gonçalves"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/menuAmigo2"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/white"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:text="•••"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#777777" />

            <!-- ITEM 3 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/fotoAmigo3"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/nomeAmigo3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:layout_toEndOf="@id/fotoAmigo3"
                    android:text="Vitoria Ferreira"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/menuAmigo3"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/white"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:text="•••"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#777777" />

            <!-- ITEM 4 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/fotoAmigo4"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/nomeAmigo4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:layout_toEndOf="@id/fotoAmigo4"
                    android:text="Marta Viana"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/menuAmigo4"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/white"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:text="•••"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#777777" />

            <!-- ITEM 5 -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="86dp"
                android:paddingHorizontal="18dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/fotoAmigo5"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_centerVertical="true"
                    app:cardCornerRadius="28dp"
                    app:cardElevation="2dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/user_placeholder" />

                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/nomeAmigo5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:layout_toEndOf="@id/fotoAmigo5"
                    android:text="Adriano de Souza"
                    android:textColor="@color/black"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/menuAmigo5"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle"
                    android:backgroundTint="@color/white"
                    android:elevation="2dp"
                    android:gravity="center"
                    android:text="•••"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="2dp"
                android:background="#777777" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>