<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavADM"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:background="#6EC1C3"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adicionar Mídia – Extras"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- FORMULÁRIO -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Quantidade de Páginas"
                    android:textColor="#1B3434"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etPaginas"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="Ex: 300"
                    android:inputType="number"
                    android:paddingStart="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Categoria"
                    android:textColor="#1B3434"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etCategoria"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="Ex: Ficção"
                    android:paddingStart="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Editora"
                    android:textColor="#1B3434"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etEditora"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="Ex: Editora Unifor"
                    android:paddingStart="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Link da Imagem de Capa"
                    android:textColor="#1B3434"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etImagem"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/bg_input_rounded"
                    android:hint="https://linkdaimagem.com"
                    android:paddingStart="15dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sinopse"
                    android:textColor="#1B3434"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etSinopse"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_input_rounded"
                    android:gravity="top"
                    android:hint="Escreva a sinopse do livro aqui..."
                    android:padding="15dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnIrVersoes"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="20dp"
                    android:text="Editar mais informações"
                    app:backgroundTint="#6EC1C3"
                    app:cornerRadius="10dp" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- BARRA ADM -->
    <LinearLayout
        android:id="@+id/bottomNavADM"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_view"/>

        <ImageView
            android:id="@+id/navFinanceiro"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_manage"/>

        <ImageView
            android:id="@+id/navSolicitacoes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_help"/>

        <ImageView
            android:id="@+id/navLivrosADM"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_agenda"/>

        <ImageView
            android:id="@+id/navUsuarios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_myplaces"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>