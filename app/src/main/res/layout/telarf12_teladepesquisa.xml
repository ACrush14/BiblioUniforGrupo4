<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER -->
    <LinearLayout
        android:id="@+id/headerSearch"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="#6EC1C3"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/btnNotificacao"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:src="@android:drawable/ic_popup_reminder"
                android:contentDescription="Notificações"
                app:tint="@android:color/black" />

            <ImageView
                android:id="@+id/btnConfig"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentEnd="true"
                android:src="@android:drawable/ic_menu_manage"
                android:contentDescription="Configurações"
                app:tint="@android:color/black" />
        </RelativeLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/profile_image_search"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:src="@mipmap/ic_launcher"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent"
            android:background="@android:color/white"
            android:padding="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Vamos procurar"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bem vindo"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- CONTENT -->
    <LinearLayout
        android:id="@+id/contentInputs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerSearch">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPorTitulo"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Procurar por Título"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:backgroundTint="#6EC1C3"
                app:cornerRadius="4dp"
                app:strokeColor="@android:color/black"
                app:strokeWidth="1dp" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPorISBN"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="Procurar por ISBN"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:backgroundTint="#6EC1C3"
                app:cornerRadius="4dp"
                app:strokeColor="@android:color/black"
                app:strokeWidth="1dp" />
        </LinearLayout>

        <!-- BARRA DE BUSCA ESTILO PILL -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input_pill"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/editPesquisa"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_toStartOf="@id/btnFiltro"
                android:background="@android:color/transparent"
                android:hint="Escreva aqui..."
                android:textSize="14sp"
                android:imeOptions="actionSearch"
                android:inputType="text" />

            <ImageView
                android:id="@+id/btnFiltro"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@android:color/black"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPesquisar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Procurar"
            android:textSize="18sp"
            android:textAllCaps="false"
            app:backgroundTint="#6EC1C3"
            app:cornerRadius="12dp" />

    </LinearLayout>

    <!-- LISTA DE RESULTADOS -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerLivros"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/contentInputs"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavContainer"
        tools:listitem="@layout/item_livro_dashboard" />

    <!-- BOTTOM NAV -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/bottom_navigation_placeholder" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
