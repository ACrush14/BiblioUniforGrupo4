<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER PREMIUM -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAlugueisAdm"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO DECORATIVO -->
        <View
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_marginStart="-120dp"
            android:layout_marginTop="-120dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- AVATAR ADM -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="41dp"
            app:cardElevation="8dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />
        </com.google.android.material.card.MaterialCardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloAlugueis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Aluguéis"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavADM"
        app:layout_constraintTop_toBottomOf="@id/headerAlugueisAdm">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="40dp">

            <!-- ITEM ALUGUEL 1 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- INFO USUÁRIO -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardImgProfile1"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#EEEEEE"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:id="@+id/imgProfile1"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/user_placeholder" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/txtName1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Ronaldo Alves"
                        android:textColor="@color/biblio_blue"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/cardImgProfile1"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardImgProfile1"
                        app:layout_constraintTop_toTopOf="@id/cardImgProfile1" />

                    <View
                        android:id="@+id/line1"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/cardImgProfile1" />

                    <!-- INFO LIVRO -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBook1"
                        android:layout_width="100dp"
                        android:layout_height="140dp"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/line1">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="90dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/o_alienista_capa" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="4dp"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="O Alienista"
                                    android:textColor="@color/biblio_blue"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:ellipsize="end"/>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="Machado de Assis"
                                    android:textColor="#666666"
                                    android:textSize="9sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/lblAlugado1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:text="Alugado em:"
                        android:textColor="#415E5E"
                        android:textSize="14sp"
                        app:layout_constraintStart_toEndOf="@id/cardBook1"
                        app:layout_constraintTop_toTopOf="@id/cardBook1" />

                    <TextView
                        android:id="@+id/txtData1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="03 fev 2026\n16:14"
                        android:textColor="@color/biblio_blue"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="@id/lblAlugado1"
                        app:layout_constraintTop_toBottomOf="@id/lblAlugado1" />

                    <!-- AÇÕES PILL -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerLivro1"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="12dp"
                        android:text="Ver livro"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:backgroundTint="@color/biblio_blue"
                        app:cornerRadius="20dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardBook1"
                        app:layout_constraintTop_toBottomOf="@id/txtData1" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerUsuario1"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="8dp"
                        android:text="Ver usuário"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:backgroundTint="@color/biblio_blue"
                        app:cornerRadius="20dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardBook1"
                        app:layout_constraintTop_toBottomOf="@id/btnVerLivro1" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ITEM ALUGUEL 2 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <!-- INFO USUÁRIO -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardImgProfile2"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="24dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#EEEEEE"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <ImageView
                            android:id="@+id/imgProfile2"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            tools:srcCompat="@tools:sample/avatars" />
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:id="@+id/txtName2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Robson Gonçalves"
                        android:textColor="@color/biblio_blue"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintBottom_toBottomOf="@id/cardImgProfile2"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardImgProfile2"
                        app:layout_constraintTop_toTopOf="@id/cardImgProfile2" />

                    <View
                        android:id="@+id/line2"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F5F5F5"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/cardImgProfile2" />

                    <!-- INFO LIVRO -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBook2"
                        android:layout_width="100dp"
                        android:layout_height="140dp"
                        android:layout_marginTop="16dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp"
                        app:strokeWidth="0dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/line2">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="90dp"
                                android:scaleType="centerCrop"
                                tools:srcCompat="@tools:sample/backgrounds/scenic" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:padding="4dp"
                                android:gravity="center_vertical">
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="O Senhor dos Anéis"
                                    android:textColor="@color/biblio_blue"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:maxLines="1"
                                    android:ellipsize="end"/>
                                <TextView
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:text="J.R.R. Tolkien"
                                    android:textColor="#666666"
                                    android:textSize="9sp"
                                    android:maxLines="1"
                                    android:ellipsize="end"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- AÇÕES PILL -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerLivro2"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="40dp"
                        android:text="Ver livro"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:backgroundTint="@color/biblio_detalhes"
                        app:cornerRadius="20dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardBook2"
                        app:layout_constraintTop_toTopOf="@id/cardBook2" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerUsuario2"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="16dp"
                        android:layout_marginTop="12dp"
                        android:text="Ver usuário"
                        android:textAllCaps="false"
                        android:textSize="13sp"
                        app:backgroundTint="@color/biblio_detalhes"
                        app:cornerRadius="20dp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/cardBook2"
                        app:layout_constraintTop_toBottomOf="@id/btnVerLivro2" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- NAV -->
    <include
        android:id="@+id/bottomNavADM"
        layout="@layout/bottom_navigation_adm"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>