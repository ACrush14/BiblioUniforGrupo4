<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerAlugueisAdm"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO -->
        <View
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.16"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="41dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloAlugueis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Alugueis"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavADM"
        app:layout_constraintTop_toBottomOf="@id/headerAlugueisAdm">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:background="@color/white"
                android:layout_marginBottom="8dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/imgProfile1"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="2dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" android:src="@drawable/user_placeholder" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/txtName1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Ronaldo Alves"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/imgProfile1"
                    app:layout_constraintStart_toEndOf="@id/imgProfile1"
                    app:layout_constraintTop_toTopOf="@id/imgProfile1" />

                <View android:id="@+id/line1" android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginTop="12dp" app:layout_constraintTop_toBottomOf="@id/imgProfile1"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBook1"
                    android:layout_width="120dp"
                    android:layout_height="180dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/line1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
                        <ImageView android:layout_width="match_parent" android:layout_height="130dp" android:scaleType="centerCrop" android:src="@drawable/o_alienista_capa" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="O Alienista" android:textColor="#333333" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="Machado de Assis" android:textColor="#666666" android:textSize="10sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView android:id="@+id/lblAlugado1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Alugado:" android:textColor="@color/black" android:textSize="20sp" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/cardBook1" app:layout_constraintTop_toTopOf="@id/cardBook1" />
                <TextView android:id="@+id/txtData1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="03 fev 2026\n16:14" android:gravity="end" android:textColor="@color/black" android:textSize="14sp" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/lblAlugado1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerLivro1"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:text="Ver livro"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/biblio_blue"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardBook1"
                    app:layout_constraintTop_toBottomOf="@id/txtData1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerUsuario1"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:text="Ver usuário"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/biblio_blue"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardBook1"
                    app:layout_constraintTop_toBottomOf="@id/btnVerLivro1" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/imgProfile2"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardCornerRadius="25dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" tools:srcCompat="@tools:sample/avatars" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/txtName2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Robson Gonçalves"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/imgProfile2"
                    app:layout_constraintStart_toEndOf="@id/imgProfile2"
                    app:layout_constraintTop_toTopOf="@id/imgProfile2" />

                <View android:id="@+id/line2" android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginTop="12dp" app:layout_constraintTop_toBottomOf="@id/imgProfile2"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBook2"
                    android:layout_width="120dp"
                    android:layout_height="180dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/line2">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
                        <ImageView android:layout_width="match_parent" android:layout_height="130dp" android:scaleType="centerCrop" tools:srcCompat="@tools:sample/backgrounds/scenic" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="O Senhor dos..." android:textColor="#333333" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="60dp"
                    android:text="Ver livro"
                    android:textAllCaps="false"
                    app:backgroundTint="#50C4C9"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardBook2"
                    app:layout_constraintTop_toTopOf="@id/cardBook2" />

                <com.google.android.material.button.MaterialButton
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="120dp"
                    android:text="Ver usuário"
                    android:textAllCaps="false"
                    app:backgroundTint="#50C4C9"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardBook2"
                    app:layout_constraintTop_toTopOf="@id/cardBook2" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

    <!-- NAV -->
    <include
        android:id="@+id/bottomNavADM"
        layout="@layout/bottom_navigation_adm"
        android:layout_width="match_parent"
        android:layout_height="74dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>