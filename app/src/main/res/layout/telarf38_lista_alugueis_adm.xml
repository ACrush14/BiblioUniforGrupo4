<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8">

    <View
        android:id="@+id/bgHeader"
        android:layout_width="0dp"
        android:layout_height="220dp"
        android:background="#50C4C9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardProfileHeader"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginTop="40dp"
        android:layout_marginEnd="30dp"
        app:cardCornerRadius="35dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            tools:srcCompat="@tools:sample/avatars" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txtTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Alugueis"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/bgHeader"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavADM"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/bgHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/imgProfile1"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardCornerRadius="25dp"
                    app:cardElevation="0dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" tools:srcCompat="@tools:sample/avatars" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/txtName1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Ronaldo Alves"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/imgProfile1"
                    app:layout_constraintStart_toEndOf="@id/imgProfile1"
                    app:layout_constraintTop_toTopOf="@id/imgProfile1" />

                <View android:id="@+id/line1" android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginTop="12dp" app:layout_constraintTop_toBottomOf="@id/imgProfile1"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBook1"
                    android:layout_width="120dp"
                    android:layout_height="180dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="4dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/line1">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
                        <ImageView android:layout_width="match_parent" android:layout_height="130dp" android:scaleType="centerCrop" tools:srcCompat="@tools:sample/backgrounds/scenic" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="O Alienista" android:textColor="#333333" android:textSize="12sp" android:textStyle="bold" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="Machado de Assis" android:textColor="#666666" android:textSize="10sp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <TextView android:id="@+id/lblAlugado1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:text="Alugado:" android:textColor="#000000" android:textSize="20sp" android:textStyle="bold" app:layout_constraintStart_toEndOf="@id/cardBook1" app:layout_constraintTop_toTopOf="@id/cardBook1" />
                <TextView android:id="@+id/txtData1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="03 fev 2026\n16:14" android:gravity="end" android:textColor="#000000" android:textSize="14sp" android:textStyle="bold" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="@id/lblAlugado1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerLivro1"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:text="Ver livro"
                    android:textAllCaps="false"
                    app:backgroundTint="#50C4C9"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardBook1"
                    app:layout_constraintTop_toBottomOf="@id/txtData1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnVerUsuario1"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="8dp"
                    android:text="Ver usuário"
                    android:textAllCaps="false"
                    app:backgroundTint="#50C4C9"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardBook1"
                    app:layout_constraintTop_toBottomOf="@id/btnVerLivro1" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/imgProfile2"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    app:cardCornerRadius="25dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <ImageView android:layout_width="match_parent" android:layout_height="match_parent" tools:srcCompat="@tools:sample/avatars" />
                </androidx.cardview.widget.CardView>

                <TextView
                    android:id="@+id/txtName2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Robson Gonçalves"
                    android:textColor="#000000"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="@id/imgProfile2"
                    app:layout_constraintStart_toEndOf="@id/imgProfile2"
                    app:layout_constraintTop_toTopOf="@id/imgProfile2" />

                <View android:id="@+id/line2" android:layout_width="match_parent" android:layout_height="1dp" android:background="#CCCCCC" android:layout_marginTop="12dp" app:layout_constraintTop_toBottomOf="@id/imgProfile2"/>

                <androidx.cardview.widget.CardView
                    android:id="@+id/cardBook2"
                    android:layout_width="120dp"
                    android:layout_height="180dp"
                    android:layout_marginTop="16dp"
                    app:cardCornerRadius="8dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/line2">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical">
                        <ImageView android:layout_width="match_parent" android:layout_height="130dp" android:scaleType="centerCrop" tools:srcCompat="@tools:sample/backgrounds/scenic" />
                        <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:text="O Senhor dos..." android:textColor="#333333" android:textSize="12sp" android:textStyle="bold" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <com.google.android.material.button.MaterialButton
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="60dp"
                    android:text="Ver livro"
                    android:textAllCaps="false"
                    app:backgroundTint="#50C4C9"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardBook2"
                    app:layout_constraintTop_toTopOf="@id/cardBook2" />

                <com.google.android.material.button.MaterialButton
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="120dp"
                    android:text="Ver usuário"
                    android:textAllCaps="false"
                    app:backgroundTint="#50C4C9"
                    app:cornerRadius="12dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/cardBook2"
                    app:layout_constraintTop_toTopOf="@id/cardBook2" />
            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavADM"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/navDashboard"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_view"/>

        <ImageView
            android:id="@+id/navFinanceiro"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_manage"/>

        <ImageView
            android:id="@+id/navSolicitacoes"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_help"/>

        <ImageView
            android:id="@+id/navLivrosADM"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_agenda"/>

        <ImageView
            android:id="@+id/navUsuarios"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="14dp"
            android:src="@android:drawable/ic_menu_myplaces"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>