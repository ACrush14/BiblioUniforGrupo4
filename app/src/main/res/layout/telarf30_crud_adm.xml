<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    tools:context=".TelaCRUDADM">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerCrudAdm"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:background="@color/biblio_detalhes"
        app:layout_constraintTop_toTopOf="parent">

        <!-- CÍRCULO -->
        <View
            android:layout_width="230dp"
            android:layout_height="230dp"
            android:layout_marginStart="-90dp"
            android:layout_marginTop="-90dp"
            android:alpha="0.15"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/white"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- FOTO -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardFotoAdm"
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:layout_marginTop="42dp"
            android:layout_marginEnd="24dp"
            app:cardCornerRadius="46dp"
            app:cardElevation="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/user_placeholder" />

        </androidx.cardview.widget.CardView>

        <!-- TÍTULO -->
        <TextView
            android:id="@+id/textTituloCrud"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tela de CRUD"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/cardFotoAdm"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="24dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- CONTEÚDO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="18dp"
        android:paddingTop="22dp"
        app:layout_constraintTop_toBottomOf="@id/headerCrudAdm">

        <!-- BOTÃO 1 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonCriarMidia"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Criar Mídia"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="10dp"
            app:elevation="3dp" />

        <!-- ESPAÇO -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="18dp" />

        <!-- BOTÃO 2 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonVerificarMidia"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Verificar Mídia"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="10dp"
            app:elevation="3dp" />

        <!-- ESPAÇO -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="18dp" />

        <!-- BOTÃO 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGerenciarUsuarios"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Gerenciar usuário"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="10dp"
            app:elevation="3dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>