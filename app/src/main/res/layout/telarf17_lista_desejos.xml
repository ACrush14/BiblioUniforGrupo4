<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7">

    <!-- HEADER (Blue/Cyan Area) -->
    <LinearLayout
        android:id="@+id/headerListaDesejos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#6EC1C3"
        android:orientation="vertical"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <ImageView
                android:id="@+id/btnNotificacao"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_alignParentStart="true"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="@android:color/black" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgPerfilUsuario"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerHorizontal="true"
                android:background="@android:color/white"
                android:padding="1dp"
                android:scaleType="centerCrop"
                android:src="@mipmap/ic_launcher"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.CornerSize50Percent" />

        </RelativeLayout>

    </LinearLayout>

    <!-- SECTION TITLE: Minha Lista de Desejo + Coração -->
    <LinearLayout
        android:id="@+id/llTituloSecao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/headerListaDesejos">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Minha Lista de Desejo"
            android:textColor="#1B3434"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="8dp"
            android:src="@android:drawable/btn_star_big_on"
            app:tint="#6EC1C3" />
            <!-- Note: Using star as heart placeholder or finding a heart if available.
                 Since it's academic, a standard icon is safer than a missing resource. -->
    </LinearLayout>

    <!-- Content: Recycler -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvListaDesejos"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/llTituloSecao"
        app:layout_constraintBottom_toTopOf="@id/includeBottomNav"
        tools:listitem="@layout/item_book_card" />

    <TextView
        android:id="@+id/txtListaVazia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sua lista de desejos está vazia."
        android:textColor="#888888"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/rvListaDesejos"
        app:layout_constraintBottom_toBottomOf="@id/rvListaDesejos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Navigation -->
    <include
        android:id="@+id/includeBottomNav"
        layout="@layout/bottom_navigation_placeholder"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
