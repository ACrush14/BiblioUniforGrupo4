<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Fundo decorativo -->
        <View
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginStart="-100dp"
            android:layout_marginTop="-100dp"
            android:alpha="0.3"
            android:background="@drawable/bg_circle"
            android:backgroundTint="@color/biblio_detalhes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Logo -->
        <ImageView
            android:id="@+id/imageLogoRecuperar"
            android:layout_width="450dp"
            android:layout_height="210dp"
            android:layout_marginTop="45dp"
            android:contentDescription="Logo"
            android:src="@drawable/unifor_marca"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Título -->
        <TextView
            android:id="@+id/textTituloRecuperar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Acesse sua Conta"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/imageLogoRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Subtítulo -->
        <TextView
            android:id="@+id/textSubtituloRecuperar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="45dp"
            android:text="Redefinir Senha"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/textTituloRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Descrição -->
        <TextView
            android:id="@+id/textDescricaoRecuperar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="48dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:text="Insira abaixo o e-mail vinculado à sua conta."
            android:textColor="#5F6368"
            android:textSize="15sp"
            app:layout_constraintTop_toBottomOf="@id/textSubtituloRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Erro -->
        <TextView
            android:id="@+id/textErroEmailRecuperar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="32dp"
            android:layout_marginTop="40dp"
            android:text="E-mail não cadastrado"
            android:textColor="@color/biblio_red"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/textDescricaoRecuperar"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Campo Email -->
        <EditText
            android:id="@+id/editEmailRecuperar"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input"
            android:hint="Digite seu e-mail"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="20dp"
            android:textColor="@color/black"
            android:textColorHint="#9E9E9E"
            app:layout_constraintTop_toBottomOf="@id/textErroEmailRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Botão -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonEnviarCodigo"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_marginHorizontal="32dp"
            android:layout_marginTop="40dp"
            android:text="Enviar Código"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/biblio_blue"
            app:cornerRadius="12dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/editEmailRecuperar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Voltar login -->
        <TextView
            android:id="@+id/textVoltarLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Retornar à tela de login"
            android:textColor="@color/biblio_detalhes"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/buttonEnviarCodigo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Espaço final -->
        <Space
            android:layout_width="0dp"
            android:layout_height="40dp"
            app:layout_constraintTop_toBottomOf="@id/textVoltarLogin"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>