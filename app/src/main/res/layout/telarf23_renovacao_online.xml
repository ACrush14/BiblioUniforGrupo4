<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/biblio_bg">

    <!-- TÍTULO -->
    <TextView
        android:id="@+id/textTituloRenovacao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="52dp"
        android:layout_marginHorizontal="28dp"
        android:gravity="center"
        android:text="Renovação de Aluguel"
        android:textColor="@color/black"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- DESCRIÇÃO -->
    <TextView
        android:id="@+id/textDescricaoRenovacao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:layout_marginHorizontal="30dp"
        android:gravity="center"
        android:lineSpacingExtra="3dp"
        android:text="Por quantos dias a mais você deseja estender o aluguel desse livro?"
        android:textColor="@color/black"
        android:textSize="21sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/textTituloRenovacao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- CARD CALENDÁRIO -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCalendario"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="34dp"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="#ECE6F0"
        app:layout_constraintTop_toBottomOf="@id/textDescricaoRenovacao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <CalendarView
            android:id="@+id/calendarRenovacao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#ECE6F0"
            android:dateTextAppearance="@style/TextAppearance.AppCompat.Body1"
            android:focusedMonthDateColor="@color/biblio_blue"
            android:showWeekNumber="false"
            android:unfocusedMonthDateColor="#777777"
            android:weekDayTextAppearance="@style/TextAppearance.AppCompat.Small" />

    </androidx.cardview.widget.CardView>

    <!-- BOTÃO CONFIRMAR -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/buttonConfirmarRenovacao"
        android:layout_width="0dp"
        android:layout_height="62dp"
        android:layout_marginTop="34dp"
        android:layout_marginHorizontal="24dp"
        android:text="Confirmar"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="bold"
        app:backgroundTint="@color/biblio_blue"
        app:cornerRadius="32dp"
        app:elevation="3dp"
        app:layout_constraintTop_toBottomOf="@id/cardCalendario"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- VOLTAR -->
    <TextView
        android:id="@+id/textVoltarRenovacao"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="Voltar"
        android:textColor="@color/biblio_blue"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/buttonConfirmarRenovacao"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>