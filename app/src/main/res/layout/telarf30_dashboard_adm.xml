<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7F7"
    tools:context="com.example.bibliounifornew.TelaRF30DashboardADM">

    <!-- HEADER -->
    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="#6EC1C3"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Config Gear -->
        <ImageView
            android:id="@+id/btnConfigAdm"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_manage"
            android:layout_alignParentStart="true"
            android:layout_marginTop="24dp"
            app:tint="#FFFFFF"
            android:contentDescription="Configurações ADM" />

        <!-- Profile Pic -->
        <androidx.cardview.widget.CardView
            android:id="@+id/profileCard"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/imgProfile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@android:drawable/ic_menu_report_image"
                android:scaleType="centerCrop"
                tools:ignore="ContentDescription" />
        </androidx.cardview.widget.CardView>

        <!-- Welcome Texts -->
        <TextView
            android:id="@+id/txtBemVindo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bem vindo"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"/>

        <TextView
            android:id="@+id/txtDashboardTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DASHBOARD DE ADM"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_below="@id/txtBemVindo"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="8dp" />

    </RelativeLayout>

    <!-- CONTENT AREA -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="-30dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD 1: USUÁRIOS E ALUGUÉIS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2"
                        android:baselineAligned="false">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Usuários" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5.785" android:textSize="26sp" android:textStyle="bold" android:textColor="#000000" android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Alugueis" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000"/>
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="342" android:textSize="26sp" android:textStyle="bold" android:textColor="#000000" android:layout_marginTop="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTelaCrud"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Tela CRUD"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 2: ANÁLISE DE ALUGUÉIS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Análise de Alugueis"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:textColor="#000000"
                        android:layout_marginBottom="16dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Março 2026" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="342" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Fevereiro 2026" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="294" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Janeiro 2026" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="648" android:textSize="18sp" android:textStyle="bold" android:textColor="#000000" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerAlugueis"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Ver Alugueis"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 3: ATRASOS -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Atrasos"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:textColor="#000000"
                        android:layout_marginBottom="16dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="João bobo" android:textSize="14sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15 dias" android:textSize="14sp" android:textColor="#000000" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Roberta sá" android:textSize="14sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3 dias" android:textSize="14sp" android:textColor="#000000" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerTodosAtrasos"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Ver todos os atrasos"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="16dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 4: CADASTROS PARA CONFIRMAR -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cadastros para confirmar"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:textColor="#000000"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jéssica Amaral" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Jeferson da Rocha" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000" android:layout_marginBottom="4dp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Roberto de Souza" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerCadastros"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Ver cadastros"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="20dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 5: SOLICITAÇÕES -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solicitações"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:textColor="#000000"
                        android:layout_marginBottom="12dp"/>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="O Jardim das Ilusões" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PDF" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Vozes do Deserto" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Braille" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Um Homem Chamado Ove" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Comprar" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000" android:layout_alignParentEnd="true"/>
                    </RelativeLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerSolicitacoesDashboard"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Ver solicitações"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="20dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD 6: SOLICITAÇÕES/RENOVAÇÕES ALUGUEL -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Solicitações/Renovações aluguel"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_gravity="center_horizontal"
                        android:textColor="#000000"
                        android:layout_marginBottom="12dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cícero Correia - Pessoas Ansiosas - 5 maio" android:textSize="16sp" android:textStyle="bold" android:textColor="#000000" android:layout_gravity="center_horizontal"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnVerRenovacoes"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:text="Ver renovações"
                        android:textAllCaps="false"
                        android:textSize="18sp"
                        app:backgroundTint="#6EC1C3"
                        app:cornerRadius="12dp"
                        android:layout_marginTop="20dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BARRA ADM PADRONIZADA -->
    <FrameLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/bottom_navigation_adm" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
